# Supabase Configuration (Server-side - KEEP SECRET)
# SUPABASE_URL - Your Supabase project URL
# SUPABASE_SECRET_KEY - Preferred server key (new Supabase format)
# SUPABASE_SERVICE_ROLE_KEY - Legacy/alternate server key name
# SUPABASE_KEY - Legacy fallback (still supported by this codebase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-secret-key

# Backend Service URL
BACKEND_URL=http://backend:8000

# Application Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
